# Database (로컬/배포 동일: compose 시 db 서비스명 사용)
DATABASE_URL=postgresql://tryl:tryl@db:5432/tryl

# Redis (로컬/배포 동일: compose 시 redis 서비스명 사용)
REDIS_URL=redis://redis:6379/0

# Try-on provider: mock | nano_banana
TRYON_PROVIDER=mock

# Sentry (error tracking)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Storage (S3 사용 시 설정)
# STORAGE_BACKEND=s3
# S3_BUCKET=your-bucket
# S3_REGION=ap-northeast-2
# S3_BASE_URL=https://your-cdn-url
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
