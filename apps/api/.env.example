# Database (composeмҷҖ лҸҷмқј м ‘мҶҚ: db:5432. нҳёмҠӨнҠём—җм„ңл§Ң мӢӨн–ү мӢң localhostлЎң ліҖкІҪ)
DATABASE_URL=postgresql://tryl:tryl@db:5432/tryl

# Redis (composeмҷҖ лҸҷмқј: redis:6379. нҳёмҠӨнҠём—җм„ңл§Ң мӢӨн–ү мӢң localhost:6379)
REDIS_URL=redis://redis:6379/0

# JWT (change in production)
JWT_SECRET=dev-secret-change-in-production

# Storage: local (default) or s3. For S3, profile images are uploaded to S3 and DB stores S3 URL for preview.
STORAGE_BACKEND=local
# S3 (when STORAGE_BACKEND=s3). Credentials via AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY; region via AWS_DEFAULT_REGION or S3_REGION.
# S3_BASE_URL optional: e.g. https://cdn.tryl.app (CloudFront) so preview URLs use this instead of bucket.s3.region.amazonaws.com
# S3_BUCKET=your-bucket
# S3_REGION=ap-northeast-2
# S3_BASE_URL=https://cdn.tryl.app

# Beta: per-account try-on limit (default 20). Set BETA_TRYON_LIMIT to change.
# BETA_TRYON_LIMIT=20

# CORS (JSON array; chrome-extension://* is allowed via regex)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Sentry (error tracking). Get DSN from https://sentry.io
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Resend (email verification). Get API key from https://resend.com
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=verify@tryl.me
