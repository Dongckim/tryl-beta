  "timepicker": {},
  "timezone": "browser",
  "title": "Tryl — 서비스 관측 개요",
  "uid": "tryl-overview",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "API 요청 (지연/처리량)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "요청 지연 p50 / p95 / p99",
      "description": "http_request_duration_seconds 히스토그램 버킷으로 계산한 분위수. 이력서의 '요청 지연 p95'.",
      "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "요청률 (status별 RPS)",
      "description": "초당 HTTP 요청 수를 상태코드별로. 에러(5xx) 급증 감지용.",
      "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "sum by (status) (rate(http_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Worker 잡 처리 (처리율/재시도율)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "잡 처리율 (completed / failed, 초당)",
      "description": "rate(tryon_jobs_processed_total[5m]) — 이력서의 '잡 처리율'.",
      "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "completed" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "sum by (status) (rate(tryon_jobs_processed_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "재시도율 (재큐잉/초) + 실패율",
      "description": "rate(tryon_job_retries_total[5m]) 와 failed 비율 — 이력서의 '재시도율'.",
      "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed 비율" }, "properties": [ { "id": "unit", "value": "percentunit" } ] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "rate(tryon_job_retries_total[5m])",
          "legendFormat": "재시도/초"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "sum(rate(tryon_jobs_processed_total{status=\"failed\"}[5m])) / clamp_min(sum(rate(tryon_jobs_processed_total[5m])), 0.0001)",
          "legendFormat": "failed 비율"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "잡 처리 시간 p95",
      "description": "histogram_quantile(0.95, ...tryon_job_duration_seconds_bucket...) — 워커 잡 자체의 p95 소요시간.",
      "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(tryon_job_duration_seconds_bucket[5m])))",
          "legendFormat": "잡 p95"
        }
      ]
    },
    {
      "type": "row",
      "title": "Redis 큐 적체 + 워커 상태",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 8,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Redis 큐 적체 (tryon:jobs 대기 길이)",
      "description": "redis_key_size{key=\"tryon:jobs\"} — 이력서의 'Redis 큐 적체'. 우상향이면 워커가 유입을 못 따라가는 신호.",
      "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 19 },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 100 } ] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["last", "max"] },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "redis_key_size{key=\"tryon:jobs\"}",
          "legendFormat": "대기 잡 수"
        }
      ]
    },
    {
      "type": "stat",
      "title": "현재 대기 잡",
      "description": "redis_key_size{key=\"tryon:jobs\"} 현재값.",
      "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 19 },
      "id": 10,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 100 } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "redis_key_size{key=\"tryon:jobs\"}",
          "legendFormat": "대기"
        }
      ]
    },
    {
      "type": "stat",
      "title": "워커 상태",
      "description": "tryon_worker_up — 1이면 워커 루프 살아있음.",
      "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 19 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-tryl" },
          "expr": "max(tryon_worker_up)",
          "legendFormat": "worker"
        }
      ]
    }
  ]
}
